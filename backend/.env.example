# ---- JSAN Tracking API : environment ----
# Copy this file to `.env` and fill real values. NEVER commit `.env`.

PORT=4000

# MongoDB Atlas. Put a FRESH password here (rotate the one that was shared in chat!).
# The /jsan_tracking segment is the database name — keep or change it.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.okk92oh.mongodb.net/jsan_tracking?retryWrites=true&w=majority&appName=Cluster0

# Auth
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=30d

# CORS: comma-separated origins for the admin panel, or * for dev
CORS_ORIGIN=*

# Tracking tuning (client sends every HEARTBEAT_INTERVAL_SECONDS; server flags stale after STALE_AFTER_SECONDS)
HEARTBEAT_INTERVAL_SECONDS=10
STALE_AFTER_SECONDS=60

# Seed account (npm run seed) — first admin login
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@jsan.local
SEED_ADMIN_PASSWORD=Admin@12345
